# Usado pelo docker-compose.yml na raiz.
# Copie para ".env" e preencha os valores reais no servidor.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=treino-ai

# Precisam bater com os valores em bootcamp-treinos-api/.env
# (API_BASE_URL / WEB_APP_BASE_URL) e sao embutidos no build do frontend.
NEXT_PUBLIC_API_URL=https://api.treino.nexux360.com.br
NEXT_PUBLIC_BASE_URL=https://treino.nexux360.com.br
